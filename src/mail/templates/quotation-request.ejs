<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>New Quotation Request</title>
  <style>
    body {
      font-family: 'Arial', sans-serif;
      background-color: #f4f4f4;
      margin: 0;
      padding: 0;
      color: #333;
    }
    .email-container {
      background-color: #ffffff;
      max-width: 640px;
      margin: 0 auto;
      padding: 24px;
      border-radius: 8px;
      box-shadow: 0 4px 6px rgba(0, 0, 0, 0.08);
    }
    .email-header {
      margin-bottom: 16px;
    }
    .email-header h1 {
      color: #1f2937;
      font-size: 22px;
      margin: 0;
    }
    .email-body {
      line-height: 1.6;
      font-size: 15px;
    }
    .meta {
      margin-top: 16px;
      margin-bottom: 16px;
      padding: 12px;
      border-radius: 6px;
      background-color: #f9fafb;
      border: 1px solid #e5e7eb;
    }
    .meta p {
      margin: 6px 0;
    }
    .support-needed {
      margin-top: 12px;
      padding: 12px;
      border-left: 4px solid #2563eb;
      background-color: #f8fbff;
      white-space: pre-wrap;
    }
    .email-footer {
      margin-top: 24px;
      font-size: 12px;
      color: #6b7280;
    }
  </style>
</head>
<body>
  <div class="email-container">
    <div class="email-header">
      <h1>New Quotation Request Received</h1>
    </div>

    <div class="email-body">
      <p>A new quotation request was submitted on <strong><%= appName %></strong>.</p>

      <div class="meta">
        <p><strong>Quotation ID:</strong> <%= quotationId %></p>
        <p><strong>Challenge Title:</strong> <%= challengeTitle %></p>
        <p><strong>User Name:</strong> <%= userName %></p>
        <p><strong>User Email:</strong> <%= userEmail %></p>
        <p><strong>Phone Number:</strong> <%= phoneNumber %></p>
        <p><strong>Submitted At (UTC):</strong> <%= submittedAt %></p>
      </div>

      <p><strong>Support Needed:</strong></p>
      <div class="support-needed"><%= supportNeeded %></div>
    </div>

    <div class="email-footer">
      <p>This is an automated notification from <%= appName %>.</p>
    </div>
  </div>
</body>
</html>
