<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Quotation Reply</title>
  <style>
    body {
      font-family: 'Arial', sans-serif;
      background-color: #f4f4f4;
      margin: 0;
      padding: 0;
      color: #333;
    }
    .email-container {
      background-color: #ffffff;
      max-width: 640px;
      margin: 0 auto;
      padding: 24px;
      border-radius: 8px;
      box-shadow: 0 4px 6px rgba(0, 0, 0, 0.08);
    }
    .email-header h1 {
      color: #111827;
      font-size: 22px;
      margin: 0 0 8px 0;
    }
    .email-body {
      line-height: 1.6;
      font-size: 15px;
    }
    .meta {
      margin-top: 14px;
      padding: 12px;
      border-radius: 6px;
      background-color: #f9fafb;
      border: 1px solid #e5e7eb;
    }
    .meta p {
      margin: 6px 0;
    }
    .reply-message {
      margin-top: 16px;
      padding: 14px;
      border-left: 4px solid #10b981;
      background-color: #f0fdf4;
      white-space: pre-wrap;
    }
    .email-footer {
      margin-top: 24px;
      font-size: 12px;
      color: #6b7280;
    }
  </style>
</head>
<body>
  <div class="email-container">
    <div class="email-header">
      <h1>Reply to Your Quotation Request</h1>
    </div>

    <div class="email-body">
      <p>Hello <%= fullName %>,</p>
      <p>Thank you for reaching out to <strong><%= appName %></strong>. We have reviewed your quotation request and shared our response below.</p>

      <div class="meta">
        <p><strong>Quotation ID:</strong> <%= quotationId %></p>
        <p><strong>Challenge Title:</strong> <%= challengeTitle %></p>
      </div>

      <p><strong>Our Reply:</strong></p>
      <div class="reply-message"><%= message %></div>

      <p>If you need any further support, feel free to reply to this email.</p>
    </div>

    <div class="email-footer">
      <p>Regards,</p>
      <p><strong><%= appName %> Team</strong></p>
    </div>
  </div>
</body>
</html>
