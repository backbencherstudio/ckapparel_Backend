generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["fullTextSearchPostgres"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Account {
  id         String   @id @default(cuid())
  created_at DateTime @default(now())
  updated_at DateTime @default(now())

  user_id String
  user    User   @relation(fields: [user_id], references: [id], onDelete: Cascade)

  type                String?
  provider            String?
  provider_account_id String?
  refresh_token       String?
  access_token        String?
  expires_at          DateTime?
  token_type          String?
  scope               String?
  id_token            String?
  session_state       String?

  @@unique([provider, provider_account_id])
  @@map("accounts")
}

model User {
  id         String    @id @default(cuid())
  created_at DateTime  @default(now())
  updated_at DateTime  @default(now())
  deleted_at DateTime?
  status     Int?      @default(1) @db.SmallInt

  approved_at  DateTime?
  availability String?

  google_id   String? @unique
  facebook_id String? @unique
  apple_id    String? @unique

  email      String? @unique
  username   String? @unique
  name       String? @db.VarChar(255)
  first_name String? @db.VarChar(255)
  last_name  String? @db.VarChar(255)
  password   String? @db.VarChar(255)
  domain     String? @unique
  avatar     String?
  bio        String? @db.Text

  phone_number  String?
  country       String?
  flag          String?
  state         String?
  city          String?
  address       String?
  zip_code      String?
  gender        String?
  date_of_birth DateTime? @db.Date
  age           Int?
  lastSeenAt    DateTime? @map("last_seen_at")

  // billing id. e.g. stripe customer id
  billing_id String?

  type              String?   @default("user")
  email_verified_at DateTime?

  is_two_factor_enabled Int?    @default(0)
  two_factor_secret     String? // secret key for two factor authentication

  accounts                  Account[]
  creator_conversations     Conversation[]    @relation("creator")
  participant_conversations Conversation[]    @relation("participant")
  receiver_messages         Message[]         @relation("receiver")
  sender_messages           Message[]         @relation("sender")
  deleted_messages          Message[]         @relation("message_deleted_by")
  receiver_notifications    Notification[]    @relation("receiver")
  sender_notifications      Notification[]    @relation("sender")
  memberships               Membership[]
  blocksInitiated           Block[]           @relation("Blocker")
  blockedBy                 Block[]           @relation("Blocked")
  callParticipations        CallParticipant[]
  startedCalls              CallSession[]     @relation("CallStartedBy")
  reportsFiled              Report[]          @relation("ReportReporter")

  user_payment_methods UserPaymentMethod[]
  user_settings        UserSetting[]
  ucodes               Ucode[]
  roles                Role[]
  role_users           RoleUser[]

  payment_transactions PaymentTransaction[]
  paymentMethods       PaymentMethod[]

  subscription            Subscription?            @relation(fields: [subscriptionId], references: [id])
  subscriptionId          String?
  challengeParticipations ChallengeParticipation[]
  challengeLeaderboards   ChallengeLeaderboard[]
  challengeJourneyLogs    ChallengeJourneyLog[]
  externalConnections     ExternalConnection[]
  syncedActivities        SyncedActivity[]
  challenges_won          Challenges[]             @relation("Challengewinner")
  challenges_created      Challenges[]             @relation("ChallengeCreator")
  sponsorships_created    Sponsorship[]            @relation("SponsorshipCreator")
  quotations              Quotation[]

  @@map("users")
}

model Ucode {
  id         String   @id @default(cuid())
  created_at DateTime @default(now())
  updated_at DateTime @default(now())
  status     Int?     @default(1) @db.SmallInt

  user_id String?
  user    User?   @relation(fields: [user_id], references: [id])

  token      String?
  email      String?
  expired_at DateTime?

  @@map("ucodes")
}

model Role {
  id         String    @id @default(cuid())
  created_at DateTime  @default(now())
  updated_at DateTime  @default(now())
  deleted_at DateTime?

  status Int?    @default(1) @db.SmallInt
  title  String?
  name   String?

  user_id String?
  user    User?   @relation(fields: [user_id], references: [id], onDelete: Cascade)

  permission_roles PermissionRole[]
  role_users       RoleUser[]
  permissions      Permission[]     @relation("PermissionToRole")

  @@map("roles")
}

model Permission {
  id         String    @id @default(cuid())
  created_at DateTime  @default(now())
  updated_at DateTime  @default(now())
  deleted_at DateTime?

  status     Int?    @default(1) @db.SmallInt
  title      String?
  action     String?
  subject    String?
  conditions String?
  fields     String?

  permission_roles PermissionRole[]
  roles            Role[]           @relation("PermissionToRole")

  @@map("permissions")
}

model PermissionRole {
  created_at DateTime @default(now())
  updated_at DateTime @default(now())

  permission_id String
  permission    Permission @relation(fields: [permission_id], references: [id], onDelete: Cascade)

  role_id String
  role    Role   @relation(fields: [role_id], references: [id], onDelete: Cascade)

  @@id([permission_id, role_id])
  @@map("permission_roles")
}

model RoleUser {
  created_at DateTime @default(now())
  updated_at DateTime @default(now())

  role_id String
  role    Role   @relation(fields: [role_id], references: [id], onDelete: Cascade)

  user_id String
  user    User   @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@id([role_id, user_id])
  @@map("role_users")
}

// this table stores notification event
model NotificationEvent {
  id         String    @id @default(cuid())
  created_at DateTime  @default(now())
  updated_at DateTime  @default(now())
  deleted_at DateTime?

  status Int?    @default(1) @db.SmallInt
  type   String?
  text   String?

  notifications Notification[]

  @@map("notification_events")
}

model Notification {
  id         String    @id @default(cuid())
  created_at DateTime  @default(now())
  updated_at DateTime  @default(now())
  deleted_at DateTime?

  read_at DateTime?

  status Int? @default(1) @db.SmallInt

  sender_id String?
  sender    User?   @relation("sender", fields: [sender_id], references: [id])

  receiver_id String?
  receiver    User?   @relation("receiver", fields: [receiver_id], references: [id])

  notification_event_id String?
  notification_event    NotificationEvent? @relation(fields: [notification_event_id], references: [id])

  entity_id String?

  @@map("notifications")
}

model UserPaymentMethod {
  id         String    @id @default(cuid())
  created_at DateTime  @default(now())
  updated_at DateTime  @default(now())
  deleted_at DateTime?

  user_id String?
  user    User?   @relation(fields: [user_id], references: [id])

  payment_method_id String?
  checkout_id       String?

  @@map("user_payment_methods")
}

model PaymentTransaction {
  id         String    @id @default(cuid())
  created_at DateTime  @default(now())
  updated_at DateTime  @default(now())
  deleted_at DateTime?

  store_id String?

  user_id String?
  user    User?   @relation(fields: [user_id], references: [id])

  order_id         String?
  type             String?  @default("order")
  withdraw_via     String?  @default("wallet")
  provider         String?
  reference_number String?
  status           String?  @default("pending")
  raw_status       String?
  amount           Decimal?
  currency         String?
  paid_amount      Decimal?
  paid_currency    String?

  @@map("payment_transactions")
}

enum Interval {
  MONTH
  YEAR
}

model SubsPlan {
  id                String  @id @default(cuid())
  name              String
  slug              String  @unique // free, premium_monthly, premium_yearly
  description       String?
  price_description String?

  // Billing details
  isFree        Boolean   @default(false)
  price         Decimal?
  currency      String?
  interval      Interval?
  intervalCount Int?

  // Stripe
  stripeProductId String?
  stripePriceId   String?

  // Trial (for free plan)
  trialDays Int?
  type      SubscriptionPlan @default(FREE)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  subscriptions Subscription[]
}

model PaymentMethod {
  id         String    @id @default(cuid())
  created_at DateTime  @default(now())
  updated_at DateTime  @default(now())
  deleted_at DateTime?

  status            Int?    @default(1) @db.SmallInt
  type              String?
  brand             String?
  last4             String?
  exp_month         Int?
  exp_year          Int?
  cardholder_name   String?
  payment_method_id String

  sort_order Int? @default(0)

  user_id String
  user    User?  @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@map("payment_methods")
}

model Subscription {
  id     String @id @default(cuid())
  userId String

  planId String
  plan   SubsPlan @relation(fields: [planId], references: [id], onDelete: Cascade)

  // Required for tracking
  startDate     DateTime  @default(now())
  endDate       DateTime?
  trialEndsAt   DateTime?
  status        String?
  remainingDays Int?

  // Plan type
  type String

  // Stripe subscription
  stripeSubId String?

  // Auto-renew
  isActive          Boolean @default(true)
  cancelAtPeriodEnd Boolean @default(false)
  isTrial           Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  users     User[]

  @@map("subscriptions")
}

enum SubscriptionPlan {
  FREE
  TRIALING
  BASIC
  PREMIUM
}

// ---------Start Chat schema---------

enum MessageStatus {
  PENDING
  SENT
  DELIVERED
  READ
}

enum ConversationType {
  DM
  GROUP
}

enum MemberRole {
  MEMBER
  ADMIN
}

enum MessageKind {
  TEXT
  IMAGE
  VIDEO
  FILE
  AUDIO
  SYSTEM
}

enum CallKind {
  AUDIO
  VIDEO
}

enum ReportStatus {
  OPEN
  REVIEWED
  RESOLVED
  DISMISSED
}

// message is used for conversation
model Message {
  id        String    @id @default(cuid())
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @default(now()) @map("updated_at")
  deletedAt DateTime? @map("deleted_at")
  readAt    DateTime? @map("read_at")

  status MessageStatus? @default(PENDING)
  kind   MessageKind    @default(TEXT)

  senderId String? @map("sender_id")
  sender   User?   @relation("sender", fields: [senderId], references: [id])

  receiverId String? @map("receiver_id")
  receiver   User?   @relation("receiver", fields: [receiverId], references: [id])

  conversationId String?       @map("conversation_id")
  conversation   Conversation? @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  attachmentId String?     @map("attachment_id")
  attachment   Attachment? @relation(fields: [attachmentId], references: [id])
  deletedById  String?     @map("deleted_by_id")
  deletedBy    User?       @relation("message_deleted_by", fields: [deletedById], references: [id])
  media_Url    String?     @map("media_url")
  content      Json?
  message      String?
  reports      Report[]

  @@index([conversationId, createdAt])
  @@index([senderId])
  @@map("messages")
}

// this table stores attachment of message
model Attachment {
  id         String    @id @default(cuid())
  created_at DateTime  @default(now())
  updated_at DateTime  @default(now())
  deleted_at DateTime?

  name     String?
  type     String?
  size     Int?
  file     String?
  file_alt String?

  messages Message[]

  @@map("attachments")
}

// this table stores conversation
model Conversation {
  id        String    @id @default(cuid())
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @default(now()) @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  type          ConversationType @default(DM)
  title         String?
  avatarUrl     String?          @map("avatar_url")
  senderTitle   String?          @map("sender_title")
  receiverTitle String?          @map("receiver_title")
  dmKey         String?          @unique @map("dm_key")
  createdBy     String?          @map("created_by")

  creatorId String? @map("creator_id")
  creator   User?   @relation("creator", fields: [creatorId], references: [id])

  participantId String? @map("participant_id")
  participant   User?   @relation("participant", fields: [participantId], references: [id])

  messages     Message[]
  memberships  Membership[]
  callSessions CallSession[]
  challenge    Challenges?   @relation("ChallengeConversation")

  @@index([type])
  @@index([updatedAt])
  @@map("conversations")
}

model Membership {
  id        String    @id @default(cuid())
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @default(now()) @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  conversationId String       @map("conversation_id")
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  userId String @map("user_id")
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  role       MemberRole @default(MEMBER)
  lastReadAt DateTime?  @map("last_read_at")
  clearedAt  DateTime?  @map("cleared_at")
  archivedAt DateTime?  @map("archived_at")

  @@unique([conversationId, userId])
  @@index([userId])
  @@index([conversationId])
  @@map("memberships")
}

model Block {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now()) @map("created_at")

  blockerId String @map("blocker_id")
  blocker   User   @relation("Blocker", fields: [blockerId], references: [id], onDelete: Cascade)

  blockedId String @map("blocked_id")
  blocked   User   @relation("Blocked", fields: [blockedId], references: [id], onDelete: Cascade)

  @@unique([blockerId, blockedId])
  @@index([blockedId])
  @@map("blocks")
}

model CallSession {
  id        String    @id @default(cuid())
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @default(now()) @map("updated_at")
  startedAt DateTime  @default(now()) @map("started_at")
  endedAt   DateTime? @map("ended_at")

  conversationId String       @map("conversation_id")
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  startedBy String @map("started_by")
  starter   User   @relation("CallStartedBy", fields: [startedBy], references: [id], onDelete: Cascade)

  kind         CallKind
  participants CallParticipant[]

  @@index([conversationId, endedAt])
  @@map("call_sessions")
}

model CallParticipant {
  id        String    @id @default(cuid())
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @default(now()) @map("updated_at")
  joinedAt  DateTime  @default(now()) @map("joined_at")
  leftAt    DateTime? @map("left_at")

  callId String      @map("call_id")
  call   CallSession @relation(fields: [callId], references: [id], onDelete: Cascade)

  userId String @map("user_id")
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([callId, userId])
  @@index([userId])
  @@map("call_participants")
}

model Report {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @default(now()) @map("updated_at")

  messageId String  @map("message_id")
  message   Message @relation(fields: [messageId], references: [id], onDelete: Cascade)

  reporterId String @map("reporter_id")
  reporter   User   @relation("ReportReporter", fields: [reporterId], references: [id], onDelete: Cascade)

  reason String?
  status ReportStatus @default(OPEN)

  @@index([messageId])
  @@index([reporterId])
  @@map("reports")
}

// ---------End Chat schema---------

model Faq {
  id         String    @id @default(cuid())
  created_at DateTime  @default(now())
  updated_at DateTime  @default(now())
  deleted_at DateTime?

  status     Int?    @default(1) @db.SmallInt
  sort_order Int?    @default(0)
  question   String?
  answer     String?

  @@map("faqs")
}

model Contact {
  id         String    @id @default(cuid())
  created_at DateTime  @default(now())
  updated_at DateTime  @default(now())
  deleted_at DateTime?

  name         String?
  email        String?
  phone_number String?
  message      String?

  @@map("contacts")
}

model SocialMedia {
  id         String    @id @default(cuid())
  created_at DateTime  @default(now())
  updated_at DateTime  @default(now())
  deleted_at DateTime?

  status     Int?    @default(1) @db.SmallInt
  sort_order Int?    @default(0)
  name       String?
  url        String?
  icon       String?

  @@map("social_medias")
}

model WebsiteInfo {
  id         String    @id @default(cuid())
  created_at DateTime  @default(now())
  updated_at DateTime  @default(now())
  deleted_at DateTime?

  name                String?
  phone_number        String?
  email               String?
  address             String?
  logo                String?
  favicon             String?
  copyright           String?
  cancellation_policy String?

  @@map("website_infos")
}

model Setting {
  id         String    @id @default(cuid())
  created_at DateTime  @default(now())
  updated_at DateTime  @default(now())
  deleted_at DateTime?

  category      String?
  label         String?
  description   String?
  key           String? @unique
  default_value String?

  user_settings UserSetting[]

  @@map("settings")
}

model UserSetting {
  id         String    @id @default(cuid())
  created_at DateTime  @default(now())
  updated_at DateTime  @default(now())
  deleted_at DateTime?

  user_id String?
  user    User?   @relation(fields: [user_id], references: [id])

  setting_id String?
  setting    Setting? @relation(fields: [setting_id], references: [id])

  value String?

  @@map("user_settings")
}

// Challanges schema

// ===== Challenge Enums =====

enum ChallengePath {
  ELITE_ATHLETE
  MONTHLY_CHALLENGE
  VIRTUAL_ADVENTURE
  COMMUNITY_CHALLENGE
}

enum ChallengeCategory {
  RUNNING
  CYCLING
  SWIMMING
  HIIT
  OTHER
}

enum ChallengeDifficulty {
  EASY
  MEDIUM
  HARD
  CHALLENGING
  EXPERT
  EXTREME
}

enum ChallengeStatus {
  ACTIVE
  PENDING
  COMPLETED
  REJECTED
}

enum ParticipationStatus {
  JOINED
  IN_PROGRESS
  COMPLETED
  PAUSED
  ABANDONED
  DISQUALIFIED
}

enum CheckpointStatus {
  LOCKED
  ACTIVE
  COMPLETED
  SKIPPED
}

enum MetricType {
  DISTANCE_KM
  ELEVATION_M
  DURATION_MIN
  CALORIES
}

enum FitnessProvider {
  STRAVA
  MANUAL
}

enum SyncedActivityStatus {
  PENDING
  PROCESSED
  IGNORED
  FAILED
}

// ===== Main Challenge Model (Clean & Simple) =====

model Challenges {
  id         String    @id @default(cuid())
  created_at DateTime  @default(now())
  updated_at DateTime  @default(now())
  deleted_at DateTime?

  // Basic Info
  title       String
  subtitle    String?
  description String?         @db.Text
  status      ChallengeStatus @default(ACTIVE)

  // Classification
  path       ChallengePath
  category   ChallengeCategory
  difficulty ChallengeDifficulty

  // Rules
  require_device_connection Boolean @default(true)
  allow_manual_submission   Boolean @default(true)
  enable_chat               Boolean @default(true)
  is_active                 Boolean @default(true)
  is_featured               Boolean @default(false)

  // Limits
  max_participants       Int?
  participants_joined    Int? @default(0)
  participants_completed Int? @default(0)

  // Rewards
  reward_title       String?
  reward_description String?

  // Location 
  challenge_country String?

  // Relations
  pathConfig     ChallengePathConfig?
  metrics        ChallengeMetric[]
  checkpoints    ChallengeCheckpoint[]
  participations ChallengeParticipation[]
  leaderboard    ChallengeLeaderboard[]
  journeyLogs    ChallengeJourneyLog[]
  routePlans     RoutePlan[]

  // Chat relation 
  conversationId String?       @unique @map("conversation_id")
  conversation   Conversation? @relation("ChallengeConversation", fields: [conversationId], references: [id], onDelete: SetNull)

  // winner info
  winner    User?   @relation("Challengewinner", fields: [winner_id], references: [id], onDelete: SetNull)
  winner_id String?

  // Creator info
  created_by String?
  creator    User?   @relation("ChallengeCreator", fields: [created_by], references: [id], onDelete: SetNull)

  @@index([path, is_active])
  @@map("challenges")
}

// ===== Path-Specific Configuration =====

model ChallengePathConfig {
  id         String   @id @default(cuid())
  created_at DateTime @default(now())
  updated_at DateTime @default(now())

  challenge_id String     @unique
  challenge    Challenges @relation(fields: [challenge_id], references: [id], onDelete: Cascade)

  // VIRTUAL_ADVENTURE: GPS route, start/end coordinates, waypoints
  // MONTHLY_CHALLENGE: Simple monthly goal
  // ELITE_ATHLETE: Tier-based thresholds
  // COMMUNITY_CHALLENGE: Team aggregation settings

  config_data Json // Path-specific settings stored as JSON
  // Examples:
  // VIRTUAL_ADVENTURE: { route_start: {lat, lng}, route_end: {lat, lng}, waypoints: [...], require_gps: true }
  // MONTHLY_CHALLENGE: { goal_type: "distance_or_elevation", monthly_reset: true }
  // ELITE_ATHLETE: { tiers: [{name: "Bronze", distance: 50}, {name: "Silver", distance: 100}, ...] }
  // COMMUNITY_CHALLENGE: { team_based: true, min_team_size: 2, aggregate_metric: "distance" }

  @@map("challenge_path_configs")
}

// ===== Metrics Definition =====

model ChallengeMetric {
  id         String   @id @default(cuid())
  created_at DateTime @default(now())
  updated_at DateTime @default(now())

  challenge_id String
  challenge    Challenges @relation(fields: [challenge_id], references: [id], onDelete: Cascade)

  metric_type   MetricType
  sequence      Int // Order for display (1 = primary)
  target_value  Decimal // e.g., 50 km, 1000m elevation, 180 minutes
  min_threshold Decimal? // Optional minimum threshold
  is_required   Boolean    @default(true)

  @@unique([challenge_id, metric_type])
  @@index([challenge_id, sequence])
  @@map("challenge_metrics")
}

// ===== Challenge Checkpoints (Simplified) =====

model ChallengeCheckpoint {
  id         String    @id @default(cuid())
  created_at DateTime  @default(now())
  updated_at DateTime  @default(now())
  deleted_at DateTime?

  challenge_id String
  challenge    Challenges @relation(fields: [challenge_id], references: [id], onDelete: Cascade)

  // Sequential milestone
  sequence    Int
  title       String
  description String?

  // Checkpoint target metrics (can be subset of challenge metrics)
  metric_targets Json // { "DISTANCE_KM": 25, "ELEVATION_M": 500 }

  // Rewards & badges
  reward_title       String?
  reward_description String?
  reward_image       String?

  // Checkpoint control
  is_visible                  Boolean @default(true)
  is_required                 Boolean @default(true)
  unlock_after_checkpoint_seq Int? // Unlock this after completing previous checkpoint

  // Strava integration (optional)
  strava_segment_id String?

  // Relations
  progress      ChallengeCheckpointProgress[]
  journeyLogs   ChallengeJourneyLog[]
  activityLinks ChallengeActivityLink[]

  @@unique([challenge_id, sequence])
  @@index([challenge_id])
  @@map("challenge_checkpoints")
}

// ===== User Participation in Challenges =====

model ChallengeParticipation {
  id         String    @id @default(cuid())
  created_at DateTime  @default(now())
  updated_at DateTime  @default(now())
  deleted_at DateTime?

  user_id String
  user    User   @relation(fields: [user_id], references: [id], onDelete: Cascade)

  challenge_id String
  challenge    Challenges @relation(fields: [challenge_id], references: [id], onDelete: Cascade)

  // Status & timeline
  status           ParticipationStatus @default(JOINED)
  joined_at        DateTime            @default(now())
  started_at       DateTime?
  completed_at     DateTime?
  last_activity_at DateTime?
  last_synced_at   DateTime?

  // Connected provider (optional)
  external_connection_id String?
  externalConnection     ExternalConnection? @relation(fields: [external_connection_id], references: [id], onDelete: SetNull)
  source_provider        FitnessProvider?

  // Aggregated progress metrics (computed from checkpoint progresses)
  progress_percent      Decimal? @default(0)
  metric_values         Json? // { "DISTANCE_KM": 25.5, "ELEVATION_M": 500, "DURATION_MIN": 120 }
  active_checkpoint_seq Int?     @default(1)

  // Relations
  checkpointProgress ChallengeCheckpointProgress[]
  journeyLogs        ChallengeJourneyLog[]
  activityLinks      ChallengeActivityLink[]

  @@unique([user_id, challenge_id])
  @@index([challenge_id, status])
  @@index([user_id, status])
  @@map("challenge_participations")
}

// ===== Leaderboard Tracking =====

model ChallengeLeaderboard {
  id         String   @id @default(cuid())
  created_at DateTime @default(now())
  updated_at DateTime @default(now())

  challenge_id String
  challenge    Challenges @relation(fields: [challenge_id], references: [id], onDelete: Cascade)

  user_id String
  user    User   @relation(fields: [user_id], references: [id], onDelete: Cascade)

  // Ranking
  rank             Int?
  progress_percent Decimal?
  metric_values    Json? // { "DISTANCE_KM": 50.2, "ELEVATION_M": 1200, "DURATION_MIN": 240 }

  // Completion
  finished_at     DateTime?
  finish_time_sec Int? // Time to complete challenge

  source_provider FitnessProvider?

  @@unique([challenge_id, user_id])
  @@index([challenge_id, rank])
  @@map("challenge_leaderboards")
}

// ===== Journey Logs (Activity Timeline) =====

model ChallengeJourneyLog {
  id         String   @id @default(cuid())
  created_at DateTime @default(now())

  user_id String
  user    User   @relation(fields: [user_id], references: [id], onDelete: Cascade)

  challenge_id String
  challenge    Challenges @relation(fields: [challenge_id], references: [id], onDelete: Cascade)

  participation_id String
  participation    ChallengeParticipation @relation(fields: [participation_id], references: [id], onDelete: Cascade)

  checkpoint_id String?
  checkpoint    ChallengeCheckpoint? @relation(fields: [checkpoint_id], references: [id], onDelete: SetNull)

  activity_id String?
  activity    SyncedActivity? @relation(fields: [activity_id], references: [id], onDelete: SetNull)

  // Event info
  event_type String? // "checkpoint_unlocked", "checkpoint_completed", "activity_linked", "milestone_reached"
  message    String?

  // Metric change from this activity
  metric_changes    Json? // { "DISTANCE_KM": 5.2, "ELEVATION_M": 100 }
  progress_snapshot Decimal? // Progress % at time of log

  source_provider FitnessProvider? @default(MANUAL)
  metadata        Json?

  @@index([challenge_id, created_at])
  @@index([user_id, challenge_id])
  @@map("challenge_journey_logs")
}

// ===== Checkpoint Progress per User Attempt =====

model ChallengeCheckpointProgress {
  id         String   @id @default(cuid())
  created_at DateTime @default(now())
  updated_at DateTime @default(now())

  participation_id String
  participation    ChallengeParticipation @relation(fields: [participation_id], references: [id], onDelete: Cascade)

  checkpoint_id String
  checkpoint    ChallengeCheckpoint @relation(fields: [checkpoint_id], references: [id], onDelete: Cascade)

  // Status tracking
  status       CheckpointStatus @default(LOCKED)
  started_at   DateTime?
  completed_at DateTime?

  // Current metric values for this checkpoint
  metric_values Json? // { "DISTANCE_KM": 15.0, "ELEVATION_M": 350 }

  // Which activity completed this checkpoint
  completed_by_activity_id String?

  source_provider FitnessProvider?
  metadata        Json?

  // Relations
  activityLinks ChallengeActivityLink[]

  @@unique([participation_id, checkpoint_id])
  @@index([checkpoint_id, status])
  @@map("challenge_checkpoint_progresses")
}

// ===== External Fitness Provider Integration =====

model ExternalConnection {
  id         String    @id @default(cuid())
  created_at DateTime  @default(now())
  updated_at DateTime  @default(now())
  deleted_at DateTime?

  user_id String
  user    User   @relation(fields: [user_id], references: [id], onDelete: Cascade)

  // Provider details
  provider         FitnessProvider
  provider_user_id String?

  // OAuth tokens
  access_token     String?   @db.Text
  refresh_token    String?   @db.Text
  token_expires_at DateTime?
  scope            String?

  // Sync status
  is_active    Boolean   @default(true)
  last_sync_at DateTime?

  // Webhook (for push updates)
  webhook_subscription_id String?

  // Additional data
  metadata Json?

  // Relations
  syncedActivities        SyncedActivity[]
  challengeParticipations ChallengeParticipation[]

  @@unique([user_id, provider])
  @@index([provider, is_active])
  @@map("external_connections")
}

// ===== Synced Activities from Providers =====

model SyncedActivity {
  id         String    @id @default(cuid())
  created_at DateTime  @default(now())
  updated_at DateTime  @default(now())
  deleted_at DateTime?

  user_id String
  user    User   @relation(fields: [user_id], references: [id], onDelete: Cascade)

  external_connection_id String?
  externalConnection     ExternalConnection? @relation(fields: [external_connection_id], references: [id], onDelete: SetNull)

  // Activity identification
  provider             FitnessProvider
  provider_activity_id String // Unique per provider

  name          String?
  sport_type    String? // "running", "cycling", "swimming", etc.
  activity_date DateTime

  // Metrics
  distance_m        Decimal?
  elevation_gain_m  Decimal?
  average_speed_mps Decimal?
  elapsed_time_sec  Int?
  moving_time_sec   Int?

  // Processing status
  status       SyncedActivityStatus @default(PENDING)
  processed_at DateTime?

  // Raw data
  raw_payload Json?

  // Relations
  challengeActivityLinks ChallengeActivityLink[]
  journeyLogs            ChallengeJourneyLog[]

  @@unique([provider, provider_activity_id])
  @@index([user_id, activity_date])
  @@index([status, created_at])
  @@map("synced_activities")
}

// ===== Activity Links to Challenges =====

model ChallengeActivityLink {
  id         String   @id @default(cuid())
  created_at DateTime @default(now())
  updated_at DateTime @default(now())

  participation_id String
  participation    ChallengeParticipation @relation(fields: [participation_id], references: [id], onDelete: Cascade)

  activity_id String
  activity    SyncedActivity @relation(fields: [activity_id], references: [id], onDelete: Cascade)

  checkpoint_progress_id String?
  checkpointProgress     ChallengeCheckpointProgress? @relation(fields: [checkpoint_progress_id], references: [id], onDelete: SetNull)

  checkpoint_id String?
  checkpoint    ChallengeCheckpoint? @relation(fields: [checkpoint_id], references: [id], onDelete: SetNull)

  // Metrics counted from this activity
  counted_metrics Json? // { "DISTANCE_KM": 5.0, "ELEVATION_M": 100, "DURATION_MIN": 30 }

  is_counted Boolean @default(true)

  @@index([checkpoint_progress_id])
  @@map("challenge_activity_links")
}

// ==========================================
// Support Plans for Challenges 
// ==========================================

enum PlanCategory {
  RUNNING
  CYCLING
  SWIMMING
  HIIT
}

enum TrainingPlansCategory {
  Beginner
  Intermediate
  Advanced
}

model PlanType {
  id         String   @id @default(cuid())
  created_at DateTime @default(now())
  updated_at DateTime @default(now())

  name         String
  description  String?       @db.Text
  supportPlans SupportPlan[]

  @@index([name])
  @@map("plan_types")
}

model SupportPlan {
  id         String   @id @default(cuid())
  created_at DateTime @default(now())
  updated_at DateTime @default(now())
  status     Int?     @default(1) @db.SmallInt

  title        String
  description  String?  @db.Text
  distance     Decimal? @db.Decimal(10, 2)
  resource_url String?
  route_url    String?

  planTypeId String
  plan_type  PlanType @relation(fields: [planTypeId], references: [id], onDelete: Cascade)

  category              PlanCategory
  trainingPlansCategory TrainingPlansCategory?

  @@map("support_plans")
}

// ==========================================
// Route Planning 
// ==========================================

model RoutePlan {
  id         String   @id @default(cuid())
  created_at DateTime @default(now())
  updated_at DateTime @default(now())
  status     Int?     @default(1) @db.SmallInt

  challenge_id String
  challenge    Challenges @relation(fields: [challenge_id], references: [id], onDelete: Cascade)

  banner_image_url        String?
  about_challenge         String?    @db.Text
  location                String?
  total_distance          String?
  average_completion_time String?
  climate_terrain         String?
  highest_point           String?
  dificulty_rating        String?
  routeDays               RouteDay[]

  @@map("route_plans")
}

model RouteDay {
  id         String   @id @default(cuid())
  created_at DateTime @default(now())
  updated_at DateTime @default(now())
  status     Int?     @default(1) @db.SmallInt

  routePlanId String
  route_plan  RoutePlan @relation(fields: [routePlanId], references: [id], onDelete: Cascade)

  sequence    Int
  day_number  String?
  title       String?
  description String? @db.Text
  distance    String?

  @@index([routePlanId, day_number])
  @@map("route_days")
}

// ==========================================
// Sponsorship Hub for Challenges
// ==========================================

enum SponsorshipStatus {
  OPEN
  CLOSED
  PENDING
  DECLINED
}

enum NeedCategory {
  FOOTWEAR
  NUTRITION
  TRANSPORTATION
  SUPPLIMENTS
  OTHER
}

model Sponsorship {
  id         String            @id @default(cuid())
  created_at DateTime          @default(now())
  updated_at DateTime          @default(now())
  status     SponsorshipStatus @default(PENDING)

  title         String
  description   String?  @db.Text
  funding_goal  Decimal? @db.Decimal(15, 2)
  amount_raised Decimal? @db.Decimal(15, 2)

  challenge_category ChallengeCategory?

  sponsorship_Needs SponsorshipNeeds[]

  creator_id String?
  creator    User?   @relation("SponsorshipCreator", fields: [creator_id], references: [id], onDelete: SetNull)

  sponsorDetails SponsorDetails[]
  

  @@map("sponsorships")
}

model SponsorshipNeeds {
  id         String   @id @default(cuid())
  created_at DateTime @default(now())
  updated_at DateTime @default(now())

  sponsorship_Id String
  sponsorship    Sponsorship @relation(fields: [sponsorship_Id], references: [id], onDelete: Cascade)

  need_category    NeedCategory?
  need_description String?

  @@index([sponsorship_Id])
  @@map("sponsorship_needs")
}

model SponsorDetails {
  id         String   @id @default(cuid())
  created_at DateTime @default(now())
  updated_at DateTime @default(now())

  sponsorship_id String
  sponsorship    Sponsorship @relation(fields: [sponsorship_id], references: [id], onDelete: Cascade)

  name         String?
  email        String?
  phone_number String?

  amount  Decimal? @db.Decimal(15, 2)
  message String?  @db.Text

  @@index([sponsorship_id])
  @@map("sponsor_details")
}

// ===== Quotation Requests =====

model Quotation {
  id         String   @id @default(cuid())
  created_at DateTime @default(now())
  updated_at DateTime @default(now())
  deleted_at DateTime?

  user_id String?
  user    User?   @relation(fields: [user_id], references: [id], onDelete: SetNull)

  // Form data from user
  challenge_title    String
  support_needed     String  @db.Text
  user_email         String
  user_name          String?
  phone_number       String?

  // Admin status
  status             String? @default("pending") // pending, reviewed, contacted, completed
  admin_notes        String? @db.Text

  @@index([user_id])
  @@index([status])
  @@index([created_at])
  @@map("quotations")
}
