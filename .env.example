# =====================================================
# APPLICATION
# =====================================================
APP_NAME=Application Name
PORT=4000
APP_URL=http://localhost:${PORT}
CLIENT_APP_URL=http://localhost:3000

# =====================================================
# SECURITY / AUTH
# =====================================================
APP_KEY=replace_with_secure_random_key
SESSION_SECRET=replace_with_secure_random_string
JWT_SECRET=replace_with_secure_random_string
JWT_EXPIRY=86400000

# =====================================================
# DATABASE
# =====================================================
DATABASE_URL=postgresql://postgres:password@127.0.0.1:5432/testdb

# =====================================================
# REDIS
# =====================================================
REDIS_HOST=your-redis-host
REDIS_PORT=10542
REDIS_USERNAME=default
REDIS_PASSWORD=your_redis_password

# =====================================================
# MAIL (SMTP)
# =====================================================
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your_email@gmail.com
MAIL_PASSWORD=your_app_password
MAIL_FROM_ADDRESS=your_email@gmail.com
MAIL_FROM_NAME="${APP_NAME}"

# =====================================================
# ADMIN CONTACT
# =====================================================
ADMIN_NAME=Admin
ADMIN_EMAIL=admin@example.com

# =====================================================
# OAUTH - WEB
# =====================================================

# Google
GOOGLE_APP_ID=
GOOGLE_APP_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:4000/api/auth/google/redirect

# Apple
APPLE_CLIENT_ID=
APPLE_TEAM_ID=
APPLE_KEY_ID=
APPLE_PRIVATE_KEY=   # must be single line with \n
APPLE_CALLBACK_URL=http://localhost:4000/api/auth/apple/redirect

# Facebook
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=
FACEBOOK_CALLBACK_URL=http://localhost:4000/api/auth/facebook/redirect

# Strava
STRAVA_CLIENT_ID=
STRAVA_CLIENT_SECRET=
STRAVA_CALLBACK_URL=http://localhost:4000/api/auth/strava/callback
STRAVA_API_BASE=https://www.strava.com
STRAVA_API_V3=https://www.strava.com/api/v3
STRAVA_SCOPES=read,activity:read,activity:read_all,profile:read_all
STRAVA_WEBHOOK_VERIFY_TOKEN=replace_with_secure_random_string
STRAVA_WEBHOOK_CALLBACK_URL=http://localhost:4000/api/strava/webhook
STRAVA_AUTO_WEBHOOK_SUBSCRIBE=false
STRAVA_AUTO_SYNC_ENABLED=false
STRAVA_AUTO_SYNC_CRON=*/30 * * * *
STRAVA_AUTO_SYNC_PER_PAGE=50
STRAVA_AUTO_SYNC_MAX_PAGES=1

# =====================================================
# OAUTH - MOBILE
# =====================================================

# Google (Android & iOS)
GOOGLE_ANDROID_APP_ID=
GOOGLE_IOS_APP_ID=
GOOGLE_MOBILE_APP_IDS=

# Apple (iOS)
APPLE_MOBILE_CLIENT_IDS=

# =====================================================
# CLOUD STORAGE (AWS)
# =====================================================
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=
AWS_BUCKET=
AWS_URL=
AWS_ENDPOINT=https://s3.us-east-2.amazonaws.com

# =====================================================
# CLOUD STORAGE (GCP)
# =====================================================
GCP_PROJECT_ID=
GCP_KEY_FILE=
GCP_API_ENDPOINT=
GCP_BUCKET=

# =====================================================
# PAYMENTS
# =====================================================

# Stripe
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# PayPal
PAYPAL_CLIENT_ID=
PAYPAL_SECRET=
PAYPAL_API=

# =====================================================
# SYSTEM USER (INITIAL SEED USER)
# =====================================================
SYSTEM_USERNAME=admin
SYSTEM_EMAIL=admin@example.com
SYSTEM_PASSWORD=change_this_securely